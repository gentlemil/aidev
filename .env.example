# Database — SQLite for local dev, swap provider + URL for PostgreSQL in production
DATABASE_URL="file:./dev.db"

# Auth.js — generate a secret with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here"

# App URL
NEXTAUTH_URL="http://localhost:3000"

# API keys and configuration for AI providers
OPENAI_API_KEY=
OPENROUTER_API_KEY=
AI_PROVIDER=

# Custom configuration for AI Devs Hub
AI_DEVS_KEY=
AI_DEVS_VERIFY_URL=

